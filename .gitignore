# ============================================================

# Ninjatronics Homelab Git Ignore

# ============================================================

# ------------------------------------------------------------

# Operating System & Editor Files

# ------------------------------------------------------------

.DS_Store
Thumbs.db

*.swp
*.swo
*~

.vscode/
.idea/

# ------------------------------------------------------------

# Environment Files

# ------------------------------------------------------------

**/.env
**/.env.*
!.env.example
!.env.sample

# ------------------------------------------------------------

# Logs

# ------------------------------------------------------------

*.log
*.Log
**/*.log

# ------------------------------------------------------------

# Secrets & Credentials

# ------------------------------------------------------------

# Raw secret files

*.secret
*.secrets

# Authentication tokens

**/*token*
node-token

# Password/API key exports

**/*password*
**/*apikey*
**/*api-key*

# OpenBao / Vault token files

.bao-token
.vault-token

# ------------------------------------------------------------

# Certificates & Keys

# ------------------------------------------------------------

*.key
*.crt
*.pem
*.pfx
*.p12
*.csr

# ------------------------------------------------------------

# Kubernetes / Kubeconfig

# ------------------------------------------------------------

*.kubeconfig
kubeconfig

# Ignore ONLY actual raw secret manifests

**/secret.yaml
**/secrets.yaml

# Ignore example encrypted/temporary secret files

**/secret.example.yaml
**/secrets.example.yaml

# Ignore directories that contain local secrets

kubernetes/**/secret/

# Explicitly allow External Secrets resources

!**/externalsecret*.yaml
!**/clustersecretstore*.yaml
!**/secretstore*.yaml

# ------------------------------------------------------------

# SOPS / Sealed Secrets

# ------------------------------------------------------------

*.dec
sealed-secrets-key*.yaml

# ------------------------------------------------------------

# Local Overrides & Developer Customizations

# ------------------------------------------------------------

**/*.local.yaml
**/*override*.yaml

# ------------------------------------------------------------

# Helm

# ------------------------------------------------------------

**/Chart.lock
**/charts/*.tgz

# ------------------------------------------------------------

# AI Tooling

# ------------------------------------------------------------

.claude/
.claude/sessions/

# ------------------------------------------------------------

# Temporary Files

# ------------------------------------------------------------

*.tmp
*.bak
*.orig

# ------------------------------------------------------------

# Terraform

# ------------------------------------------------------------

.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.*
crash.log

# ------------------------------------------------------------

# Python

# ------------------------------------------------------------

**pycache**/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ------------------------------------------------------------

# Node.js

# ------------------------------------------------------------

node_modules/

# ------------------------------------------------------------

# Misc

# ------------------------------------------------------------

skills-lock.json

