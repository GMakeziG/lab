apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: excalidash-backend-secrets
  namespace: excalidash-test
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: openbao
    kind: ClusterSecretStore
  target:
    name: excalidash-backend-secrets
    creationPolicy: Owner
  data:
    - secretKey: JWT_SECRET
      remoteRef:
        key: secret/excalidash/test
        property: JWT_SECRET
    - secretKey: CSRF_SECRET
      remoteRef:
        key: secret/excalidash/test
        property: CSRF_SECRET
